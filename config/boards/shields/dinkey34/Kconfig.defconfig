if SHIELD_DINKEY34_LEFT

config ZMK_KEYBOARD_NAME
	default "Dinkey34"

config ZMK_SPLIT_BLE_ROLE_CENTRAL
	default y

endif

if SHIELD_DINKEY34_RIGHT

config ZMK_KEYBOARD_NAME
	default "Dinkey34 Right"

endif

if SHIELD_DINKEY34_LEFT || SHIELD_DINKEY34_RIGHT

config ZMK_SPLIT
	default y

endif